{
  "version": 2,
  "installCommand": "npm install --legacy-peer-deps --no-audit --include=dev",
  "buildCommand": "npm install --legacy-peer-deps --no-audit --include=dev && npm run build",
  "outputDirectory": "dist/client",
  "env": {
    "NODE_ENV": "production"
  },
  "crons": [
    {
      "path": "/api/cron-poll",
      "schedule": "* * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
