{
  "version": 2,
  "installCommand": "rm -rf node_modules package-lock.json && npm install --registry https://registry.npmjs.org/",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
