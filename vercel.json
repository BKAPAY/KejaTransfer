{
  "version": 2,
  "installCommand": "npm ci --legacy-peer-deps",
  "buildCommand": "npm ci && npm run build",
  "outputDirectory": "dist/client",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
