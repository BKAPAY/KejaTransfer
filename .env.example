# ===== DATABASE =====
# IMPORTANT: Change this to your actual Neon database URL
DATABASE_URL=postgresql://user:password@ep-xxxxx.neon.tech/neondb?sslmode=require

# ===== SERVER CONFIGURATION =====
NODE_ENV=production
PORT=3000

# ===== BASE URL =====
# Change this to your Vercel domain or custom domain
BASE_URL=https://your-domain.vercel.app

# ===== PAYDUNYA (Optional - Replace with your live keys) =====
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_PUBLIC_KEY=
PAYDUNYA_TOKEN=

# ===== OPENAI (Optional) =====
OPENAI_API_KEY=

# ===== EMAIL/SMTP (Optional) =====
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# ===== WEBHOOK SECRETS (Optional) =====
WEBHOOK_SECRET=your-webhook-secret
PAYDUNYA_WEBHOOK_SECRET=
