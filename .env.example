# ===== REQUIRED (Vercel + Neon) =====
# Neon connection string, example:
# DATABASE_URL=******ep-xxxx.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Generate a long random string, e.g.: openssl rand -hex 32
SESSION_SECRET=

# ===== SERVER =====
NODE_ENV=production
PORT=3000

# Public app URL used in callbacks and links
BASE_URL=https://your-domain.vercel.app
# If BASE_URL is omitted, Vercel runtime URLs are used automatically when available

# Optional fallback automatically set by Vercel at runtime
VERCEL_URL=

# ===== PAYMENT PROVIDERS / WEBHOOKS =====
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_PUBLIC_KEY=
PAYDUNYA_TOKEN=
MBIYOPAY_WEBHOOK_SECRET=

# ===== EXTERNAL SERVICES =====
EXCHANGERATE_API_KEY=
OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=
